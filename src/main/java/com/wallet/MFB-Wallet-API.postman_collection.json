            }
          }
        ]
      },
  
      {
        "name": "06. Edge Cases & Security",
        "item": [
          {
            "name": "No Token (expect 401)",
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects unauthenticated request', () => pm.response.to.have.status(401));"
                ]
              }
            }],
            "request": {
              "method": "GET",
              "header": [],
              "url": "{{base_url}}/api/v1/wallet/balance"
            }
          },
  
          {
            "name": "Invalid Token (expect 401)",
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects invalid token', () => pm.response.to.have.status(401));"
                ]
              }
            }],
            "request": {
              "method": "GET",
              "header": [{ "key": "Authorization", "value": "Bearer this.is.not.valid" }],
              "url": "{{base_url}}/api/v1/wallet/balance"
            }
          },
  
          {
            "name": "Transfer to Self (expect 400)",
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects self-transfer', () => pm.response.to.have.status(400));"
                ]
              }
            }],
            "request": {
              "method": "POST",
              "header": [
                { "key": "Authorization", "value": "Bearer {{token}}" },
                { "key": "Content-Type",  "value": "application/json" }
              ],
              "url": "{{base_url}}/api/v1/wallet/transfer",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"receiverAccountNumber\": \"{{account_number}}\",\n  \"amount\": 1000.00,\n  \"narration\": \"To myself\",\n  \"reference\": \"SELF-{{$randomUUID}}\"\n}"
              }
            }
          },
  
          {
            "name": "Transfer — Negative Amount (expect 400)",
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects negative amount', () => pm.response.to.have.status(400));"
                ]
              }
            }],
            "request": {
              "method": "POST",
              "header": [
                { "key": "Authorization", "value": "Bearer {{token}}" },
                { "key": "Content-Type",  "value": "application/json" }
              ],
              "url": "{{base_url}}/api/v1/wallet/transfer",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"receiverAccountNumber\": \"{{receiver_account}}\",\n  \"amount\": -500.00,\n  \"narration\": \"Negative\",\n  \"reference\": \"NEG-{{$randomUUID}}\"\n}"
              }
            }
          }
        ]
      }
  
    ]
  }
  
  